{
  "manifest_version": 3,
  "name": "Prompt Fusion",
  "version": "0.1.0",
  "description": "One prompt → ChatGPT + Gemini + Claude → synthesized answer.",
  "permissions": ["tabs", "storage", "scripting", "alarms"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*"
  ],
  "action": { "default_popup": "popup/popup.html" },
  "background": { "service_worker": "background/background.js" },
  "content_scripts": [
    { "matches": ["https://chatgpt.com/*"], "js": ["lib/selectors.js", "providers/base.js", "providers/chatgpt.js"], "run_at": "document_idle" },
    { "matches": ["https://gemini.google.com/*"], "js": ["lib/selectors.js", "providers/base.js", "providers/gemini.js"], "run_at": "document_idle" },
    { "matches": ["https://claude.ai/*"], "js": ["lib/selectors.js", "providers/base.js", "providers/claude.js"], "run_at": "document_idle" }
  ],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
